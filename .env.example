# ──────────────────────────────────────────────────────────────────
# AdTracker — Environment Configuration
# Copy this to .env and fill in your values
# ──────────────────────────────────────────────────────────────────

# Slack incoming webhook URL (get from https://api.slack.com/apps → Incoming Webhooks)
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# Path to input CSV (default: ./seed.csv)
CSV_PATH=./seed.csv

# SQLite database path (default: ./data/app.db)
DB_PATH=./data/app.db

# DATABASE_URL is auto-set from DB_PATH — you can override here
# DATABASE_URL=file:./data/app.db

# Scraper concurrency (default: 2, keep low to avoid rate limiting)
CONCURRENCY=2

# Delay between brand scrapes in ms + up to 60% jitter (default: 2500)
REQUEST_DELAY_MS=2500

# Max ads to capture per brand (default: 25)
MAX_ADS_PER_BRAND=25

# Run browser headless? (default: true — set to false to watch it run)
HEADLESS=true

# Custom User-Agent (default: realistic Chrome UA)
# USER_AGENT=Mozilla/5.0 (Macintosh; Intel Mac OS X 10_15_7) ...

# Base URL for links in Slack messages (default: http://localhost:3000)
UI_BASE_URL=http://localhost:3000
